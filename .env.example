# Gemini API key - lay tai https://aistudio.google.com/apikey
GEMINI_API_KEY=AIza...

# Model dung cho agent va embedding.
# Luu y: dong gemini-2.5 khong con mo cho tai khoan moi, dung dong 3.x.
CHAT_MODEL=gemini-3.1-flash-lite
EMBEDDING_MODEL=gemini-embedding-001
EMBEDDING_DIM=768

# PostgreSQL 18 cai san tren may
DATABASE_URL=postgresql://postgres:your_password@localhost:5432/academic_advisor

# Xac thuc
# Khoa ky access token. Bat buoc, toi thieu 32 ky tu, khong co gia tri mac dinh.
# Sinh mot khoa moi: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=
# Hai claim noi len rang token duoc cap boi dich vu nay va danh cho dich vu nay.
JWT_ISSUER=academic-advisor
JWT_AUDIENCE=academic-advisor-api

# Access token khong duoc luu o dau, nen khong rut lai duoc truoc han. Thoi gian song cua no
# CHINH LA do tre cua viec thu hoi: mot phien bi thu hoi van dung duoc toi da ngan nay phut.
# Do la cai gia cua viec khong phai cham vao database o moi request.
ACCESS_TOKEN_TTL_MINUTES=15

# Refresh token thi song lau, nen bat buoc phai thu hoi duoc, nen no duoc luu trong database.
REFRESH_TOKEN_TTL_DAYS=14

# Cookie refresh co mang co Secure hay khong. Bat o moi noi that.
# Chi dat false khi chay local qua http, vi trinh duyet se khong bao gio gui mot cookie Secure
# qua ket noi khong ma hoa, va nhu vay thi refresh se khong chay duoc tren may cua ban.
COOKIE_SECURE=false
# Sai mat khau qua so lan nay thi khoa tam thoi, de khong ai do mat khau bang cach thu mai.
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=15

# Khoa rieng cho /metrics va /stats. Bat buoc, toi thieu 32 ky tu.
# Hai endpoint nay bao cao chi phi va so token, la viec cua nguoi van hanh chu khong phai
# cua sinh vien, nen chung khong dung token dang nhap cua sinh vien.
# Sinh mot khoa moi: python -c "import secrets; print(secrets.token_urlsafe(48))"
METRICS_TOKEN=

# Gioi han an toan
MAX_TOOL_ITERATIONS=5
RETRIEVAL_TOP_K=4

# Hoc ky dang mo dang ky
CURRENT_SEMESTER=2026.1

# Tran tin chi moi ky, tuy theo trang thai hoc vu cua sinh vien.
# Sinh vien bi canh bao hoc vu chi duoc dang ky it hon.
MAX_CREDITS_BINH_THUONG=24
MAX_CREDITS_CANH_BAO_1=18
MAX_CREDITS_CANH_BAO_2=14
